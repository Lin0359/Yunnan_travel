    {
      "id": "xishuangbanna",
      "name": "西双版纳",
      "summary": "热带雨林+夜市慢游，安排 3 天喂象、泼水、徒步、夜市与村寨穿插，注意防晒和雨具。",
      "hotels": [
        {
          "name": "纳伽 S 酒店（告庄核心）",
          "price": "￥450-650/晚（旺季浮动）",
          "note": "新开业泰式酒店，步行 2 分钟到大金塔，面向泳池房相对安静，可预约接机和包车。",
          "link": ""
        },
        {
          "name": "泼水广场周边连锁/民宿",
          "price": "￥300-450/晚",
          "note": "靠近交通窗口和本地餐馆，夜间更安静，打车 15 分钟可到告庄。",
          "link": ""
        }
      ],
      "spots": [
        {
          "name": "野象谷",
          "price": "￥60 门票",
          "note": "08:30-17:30，唯一可看野象演出的公园，可坐索道、喂象，建议上午去避开暴晒。",
          "link": ""
        },
        {
          "name": "中科院热带植物园（西区优先）",
          "price": "￥130 门票+观光车",
          "note": "08:00-18:00，热带植物天堂，可安排半天到一天，滴滴站点巴士直达。",
          "link": ""
        },
        {
          "name": "傣族园",
          "price": "￥45 门票",
          "note": "8:30-17:30，每日 14:00 有泼水活动，可与植物园组合行程。",
          "link": ""
        },
        {
          "name": "曼听公园 + 总佛寺",
          "price": "￥40 起",
          "note": "上午赏傣王御花园，连通总佛寺，记得穿过膝衣物；可租傣服拍照。",
          "link": ""
        },
        {
          "name": "星光夜市 & 告庄夜景",
          "price": "免费",
          "note": "18:00-24:00，亚洲最大夜市，集中少数民族市集与拍照机位，适合夜间觅食。",
          "link": ""
        },
        {
          "name": "曼贺纳自然村寨 / 曼掌村 / 曼远村",
          "price": "凭完好村寨票或免票",
          "note": "9:00-21:00，小众文创与手作店集中，可体验村寨慢生活，需提前预约滴滴返程。",
          "link": ""
        }
      ],
      "food": [
        {
          "name": "菌喜四季·云南野生菌火锅",
          "price": "人均￥120-150",
          "note": "夜市旁鲜菌火锅，汤底清甜，适合夜游后补充能量。",
          "link": ""
        },
        {
          "name": "傣十二四季云南菜（孔崔城店）",
          "price": "人均￥90-120",
          "note": "经典傣味口味稳健，糯米饭和咖喱面值得一试。",
          "link": ""
        },
        {
          "name": "椿楣 / 缅花小吃 / 铜矿小吃",
          "price": "人均￥60-100",
          "note": "本地人常去的傣味与烧烤，炸蔬菜、糯米饭、炒菜都评价高，错开饭点排队少。",
          "link": ""
        },
        {
          "name": "双味缘傣味包烧 + 杨合林烤鱼",
          "price": "人均￥80-120",
          "note": "本地宝藏老店，包烧、烤鱼与牛胸膘评价好，可与夜市行程串联。",
          "link": ""
        },
        {
          "name": "咖啡/甜品：颂秘翁、泰泐咖啡",
          "price": "人均￥40-60",
          "note": "泰式咖啡和奶茶香浓，可在午后避暑歇脚。",
          "link": ""
        }
      ],
      "transport": [
        {
          "day": "到达",
          "note": "飞机直达嘎洒机场（打车 20 分钟到告庄）或昆明高铁 3 小时；机场大巴 4 路可入市区。"
        },
        {
          "day": "市区",
          "note": "告庄/泼水广场打车起步约￥8，共享电动车￥3/次，旺季注意电量；滴滴站点巴士覆盖主要景点。"
        },
        {
          "day": "景点",
          "note": "野象谷、傣族园、中科院植物园可预约景区直通车；去曼掌/曼远/八朵村建议包车或提前约滴滴。"
        },
        {
          "day": "注意事项",
          "note": "雨林行程需防晒、防蚊、轻薄外套；避开路边黑车，返程注意机场可能延误。"
        }
      ],
      "budget": "人均 ￥400-600/天（含餐食、交通与门票），旺季住宿需提前 1-2 周预订。"
    },
